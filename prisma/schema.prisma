generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  CONTENT_MANAGER
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SessionType {
  ONE_ON_ONE
  GROUP
}

enum SessionStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

enum AssignmentType {
  PRACTICE
  PERFORMANCE
  THEORY
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  REVISION_REQUESTED
}

enum RecordingType {
  PRACTICE
  ASSIGNMENT
  REFERENCE
  LIVE_CLASS
}

enum ResourceType {
  PDF
  AUDIO
  VIDEO
  LINK
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CourseStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum EventType {
  CONCERT
  WORKSHOP
  MASTERCLASS
  SHOWCASE
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  role      Role       @default(STUDENT)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  student       StudentProfile?
  teacher       TeacherProfile?
  notifications Notification[]
  recordings    Recording[]
  settings      UserSettings?
  posts         Post[]
  comments      Comment[]

  @@map("users")
}

model StudentProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  avatar      String?
  bio         String?
  level       Level    @default(BEGINNER)
  xp          Int      @default(0)
  streak      Int      @default(0)
  ragas       String[]

  enrollments  Enrollment[]
  submissions  AssignmentSubmission[]
  attendance   Attendance[]

  @@map("student_profiles")
}

model TeacherProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName    String
  avatar         String?
  bio            String?
  specialization String[]
  hourlyRate     Float    @default(0)
  rating         Float    @default(0)
  totalRatings   Int      @default(0)
  isVerified     Boolean  @default(false)

  courses     Course[]
  sessions    Session[]
  assignments Assignment[]
  resources   Resource[]
  earnings    Earning[]

  @@map("teacher_profiles")
}

model Course {
  id          String       @id @default(cuid())
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id])
  title       String
  description String?
  level       Level        @default(BEGINNER)
  ragas       String[]
  price       Float        @default(0)
  isPublished Boolean      @default(false)
  status      CourseStatus @default(PENDING_REVIEW)
  thumbnail   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  enrollments  Enrollment[]
  sessions     Session[]
  assignments  Assignment[]

  @@map("courses")
}

model Enrollment {
  id         String           @id @default(cuid())
  studentId  String
  student    StudentProfile   @relation(fields: [studentId], references: [id])
  courseId   String
  course     Course           @relation(fields: [courseId], references: [id])
  enrolledAt DateTime         @default(now())
  status     EnrollmentStatus @default(ACTIVE)
  paymentRef String?
  paidAmount Float            @default(0)

  @@unique([studentId, courseId])
  @@map("enrollments")
}

model Session {
  id           String        @id @default(cuid())
  teacherId    String
  teacher      TeacherProfile @relation(fields: [teacherId], references: [id])
  courseId     String?
  course       Course?       @relation(fields: [courseId], references: [id])
  title        String?
  scheduledAt  DateTime
  duration     Int
  type         SessionType   @default(ONE_ON_ONE)
  status       SessionStatus @default(SCHEDULED)
  notes        String?
  meetingUrl   String?
  recordingUrl String?
  isRecurring  Boolean       @default(false)
  createdAt    DateTime      @default(now())

  attendance Attendance[]

  @@map("sessions")
}

model Attendance {
  id        String           @id @default(cuid())
  sessionId String
  session   Session          @relation(fields: [sessionId], references: [id])
  studentId String
  student   StudentProfile   @relation(fields: [studentId], references: [id])
  status    AttendanceStatus @default(PRESENT)

  @@unique([sessionId, studentId])
  @@map("attendance")
}

model Assignment {
  id                    String         @id @default(cuid())
  teacherId             String
  teacher               TeacherProfile @relation(fields: [teacherId], references: [id])
  courseId              String?
  course                Course?        @relation(fields: [courseId], references: [id])
  title                 String
  description           String?
  type                  AssignmentType @default(PRACTICE)
  raga                  String?
  dueDate               DateTime?
  referenceRecordingUrl String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      StudentProfile   @relation(fields: [studentId], references: [id])
  recordingUrl String?
  notes        String?
  status       SubmissionStatus @default(SUBMITTED)
  score        Int?
  feedback     String?
  submittedAt  DateTime         @default(now())
  gradedAt     DateTime?

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

model Resource {
  id          String         @id @default(cuid())
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id])
  title       String
  type        ResourceType
  url         String
  raga        String?
  level       Level?
  sharedWith  String[]
  createdAt   DateTime       @default(now())

  @@map("resources")
}

model Recording {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  url       String
  duration  Int?
  type      RecordingType @default(PRACTICE)
  raga      String?
  createdAt DateTime      @default(now())

  @@map("recordings")
}

model Earning {
  id          String         @id @default(cuid())
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id])
  studentId   String?
  courseId    String?
  amount      Float
  status      PaymentStatus  @default(PENDING)
  razorpayId  String?
  description String?
  createdAt   DateTime       @default(now())

  @@map("earnings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifAssignments   Boolean  @default(true)
  notifSessions      Boolean  @default(true)
  notifReminders     Boolean  @default(true)
  notifMarketing     Boolean  @default(false)
  notifNewStudents   Boolean  @default(true)
  notifSubmissions   Boolean  @default(true)
  notifPayments      Boolean  @default(true)
  autoAcceptEnroll   Boolean  @default(false)
  profileVisibility  String   @default("students")
  progressVisibility String   @default("teacher")
  updatedAt          DateTime @updatedAt

  @@map("user_settings")
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        EventType @default(CONCERT)
  artists     String[]
  date        DateTime
  time        String
  venue       String
  seats       Int       @default(100)
  booked      Int       @default(0)
  price       Float     @default(0)
  tags        String[]
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())

  registrations EventRegistration[]

  @@map("events")
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@map("event_registrations")
}

model Post {
  id           String   @id @default(cuid())
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])
  category     String
  title        String
  body         String
  tags         String[]
  pinned       Boolean  @default(false)
  likedBy      String[]
  bookmarkedBy String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  comments Comment[]

  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@map("comments")
}
